{
  "name": "Dev Container",

  "build": {
    "dockerfile": "Dockerfile"
  },

  "settings": {
    "terminal.integrated.defaultProfile.linux": "zsh",
    "editor.formatOnSave": true
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "ms-vscode-remote.remote-containers",
        "esbenp.prettier-vscode",
        "evondev.indent-rainbow-palettes",
        "Boto3typed.boto3-ide"
      ]
    }
  },

  "mounts": [
    /* ✅ Mount deploy key for dotfiles access */
    "source=${env:HOME}/.ssh/dotfiles_deploy_key,target=/root/.ssh/dotfiles_deploy_key,type=bind,consistency=cached",

    /* ✅ Optional — full .ssh access (may conflict with above if not careful) */
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,consistency=cached",

    /* ✅ AWS config and cached SSO credentials */
    "source=${localEnv:HOME}/.aws,target=/root/.aws,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.aws/sso/cache,target=/root/.aws/sso/cache,type=bind,consistency=cached",

    /* ✅ Your local dotfiles repo */
    "source=${localEnv:HOME}/code/dotfiles,target=/root/code/dotfiles,type=bind,consistency=cached",

    /* ✅ Fallback token for HTTPS dotfiles access */
    "source=${env:HOME}/.dotfiles_token,target=/root/.dotfiles_token,type=bind,consistency=cached"
  ],


  "remoteUser": "root",
  "updateRemoteUserUID": true,

  // ⛔ overrideCommand should be false or removed unless you're explicitly overriding CMD in Dockerfile
  "overrideCommand": false,

  "remoteEnv": {
    "HOME": "/root",
    "SHELL": "/usr/bin/zsh"
  },

  "postCreateCommand": "bash .devcontainer/bootstrap.sh"
}
